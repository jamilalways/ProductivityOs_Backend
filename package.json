{
  "name": "productivity-os-backend",
  "version": "1.0.0",
  "description": "ProductivityOS — REST API (Node.js + Express + MongoDB)",
  "main": "server.js",
  "scripts": {
    "start":      "node server.js",
    "dev":        "nodemon server.js",
    "test":       "jest --detectOpenHandles --forceExit",
    "test:watch": "jest --watch"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "testTimeout": 20000
  },
  "dependencies": {
    "bcryptjs":           "^2.4.3",
    "cors":               "^2.8.5",
    "dotenv":             "^16.3.1",
    "express":            "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet":             "^7.1.0",
    "jsonwebtoken":       "^9.0.2",
    "mongoose":           "^8.0.3",
    "morgan":             "^1.10.0",
    "node-cron":          "^3.0.3",
    "validator":          "^13.11.0"
  },
  "devDependencies": {
    "jest":      "^29.7.0",
    "nodemon":   "^3.0.2",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
